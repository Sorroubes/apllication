<script>
    // ===================================================
    //  ФУНКЦІЯ ОНОВЛЕННЯ ПОПЕРЕДНЬОГО ПЕРЕГЛЯДУ
    // ===================================================
    function updatePreview() {
        // Зчитуємо дані з форми
        const appNumber = document.getElementById('appNumber').value || '_____';
        const orgName = document.getElementById('orgName').value || '___________';
        const orgShort = document.getElementById('orgShort').value || '___________';
        const legalAddr = document.getElementById('legalAddress').value || '___________';
        const edrpou = document.getElementById('edrpou').value || '___________';
        const ipn = document.getElementById('ipn').value || '___________';
        const scope = document.getElementById('scope').value || '___________';
        const dk016 = document.getElementById('dk016').value || '___________';
        const dk009 = document.getElementById('dk009').value || '___________';
        const physicalAddr = document.getElementById('physicalAddress').value || 'не вказано';
        const bankDetails = document.getElementById('bankDetails').value || '___________';
        const phone = document.getElementById('phone').value || '___________';
        const emailContact = document.getElementById('emailContact').value || '___________';
        const contactPosition = document.getElementById('contactPosition').value || '___________';
        const contactName = document.getElementById('contactName').value || '___________';
        const totalStaff = document.getElementById('totalStaff').value || '___';
        const effectiveStaff = document.getElementById('effectiveStaff').value || '___';
        const shifts = document.getElementById('shifts').value || '___';

        // Автоматична дата (сьогодні)
        const today = new Date();
        const dateStr = today.toLocaleDateString('uk-UA', {
            day: '2-digit', month: '2-digit', year: 'numeric'
        });

        // Формуємо HTML-код заявки згідно з документом ТФ-1-СУЯ
        const docHtml = `
            <div class="header-right">
                <strong>Заступнику керівника</strong><br>
                органа сертифікації систем менеджменту<br>
                <strong>ДП «ДНІПРОСТАНДАРТМЕТРОЛОГІЯ»</strong><br>
                <strong>КРИВОРІЗЬКА ФІЛІЯ</strong><br>
                вул. Криворіжсталі, 23 м. Кривий Ріг, 50005
            </div>

            <div class="doc-title">ЗАЯВКА</div>
            <div style="text-align:center; font-size:15px; margin-bottom:12px;">
                № <span class="fill">${appNumber}</span> від <span class="fill">${dateStr}</span>
            </div>
            <div style="text-align:center; font-size:15px; font-weight:700; margin-bottom:22px;">
                на проведення сертифікації системи управління якістю
            </div>

            <!-- Пункт 1 -->
            <div class="p">
                <span class="label">1</span>
                <span class="fill">${orgName}</span> (скорочено - <span class="fill">${orgShort}</span>),
                <span class="fill">${legalAddr}</span>, код ЄДРПОУ <span class="fill">${edrpou}</span>,
                ІПН <span class="fill">${ipn}</span> в особі керівника організації Сендецької Ольги Олександрівни,
                просить провести сертифікацію системи управління якістю.
            </div>

            <!-- Пункт 2 -->
            <div class="p">
                <span class="label">2</span> Відомості про систему управління якістю та про виробництво продукції (надання послуг).
            </div>
            <div class="p" style="padding-left:25px;">
                2.1 Система управління якістю впроваджена в <strong>2025 році</strong> та задовольняє вимогам стандарту <strong>ДСТУ ISO 9001:2015, ДСТУ EN ISO 9001:2018</strong>.
            </div>
            <div class="p" style="padding-left:25px;">
                2.2 Функціонування системи управління якістю контролюється шляхом проведення регулярних внутрішніх перевірок. Ефективність системи управління якістю оцінюється на підставі аналізу результатів перевірок.
            </div>
            <div class="p" style="padding-left:25px;">
                2.3 Загальний опис системи управління якістю міститься у таких основних документах: <strong>НЯ 01-2025 «Настанова щодо якості», Інструкція «Управління ризиками».</strong>
            </div>
            <div class="p" style="padding-left:25px;">
                2.4 Позначення та назва стандарту (державного, міждержавного, міжнародного), на відповідність якому передбачено перевірити (оцінити) систему управління якістю:<br>
                <strong>ДСТУ ISO 9001:2015 «Системи управління якістю. Вимоги»,</strong><br>
                <strong>ДСТУ EN ISO 9001:2018 «Системи управління якістю. Вимоги»,</strong>
            </div>
            <div class="p" style="padding-left:25px;">
                2.5 Назва продукції (послуги), щодо якої передбачено перевірити (оцінити) систему управління якістю: <strong><span class="fill">${scope}</span></strong> (коди згідно ДК 016:2010: <strong><span class="fill">${dk016}</span></strong>; коди згідно ДК 009:2010: <strong><span class="fill">${dk009}</span></strong>).
            </div>
            <div class="p" style="padding-left:25px;">
                2.6 Позначення стандарту(ів), чи інших нормативних документів, згідно з якими виробляється продукція (надаються послуги): <strong>чинна нормативна документація України.</strong>
            </div>

            <!-- Пункт 3 -->
            <div class="p" style="margin-top:14px;">
                <span class="label">3</span> Заявник зобов'язується:
            </div>
            <ul class="list" style="list-style-type:'- '; padding-left:30px;">
                <li>виконувати всі умови сертифікації;</li>
                <li>оплатити всі витрати, пов'язані з проведенням робіт з сертифікації системи управління якістю, незалежно від їх результатів.</li>
            </ul>

            <!-- Пункт 4 -->
            <div class="p" style="margin-top:14px;">
                <span class="label">4</span> Додаткові відомості:
            </div>
            <div class="p" style="padding-left:25px;">
                4.1 Заявка на сертифікацію системи управління якістю в інші Органи сертифікації не подавалась.
            </div>
            <div class="p" style="padding-left:25px;">
                4.2 Загальна чисельність персоналу: <span class="fill"><strong>${totalStaff}</strong></span> чол. (в тому числі ефективного - <span class="fill"><strong>${effectiveStaff}</strong></span>)
                <br><span style="font-size:12px; color:#444;">* Ефективна чисельність персоналу складається з усього персоналу (постійного, тимчасового та позаштатного), залученого до сфери сертифікації, включно з тим, хто працює в кожну зміну. У разі включення в сферу сертифікації, вона також повинна включати непостійний персонал (наприклад, підрядники)</span>
            </div>
            <div class="p" style="padding-left:25px;">
                4.3 Кількість змін: <span class="fill"><strong>${shifts}</strong></span>
            </div>
            <div class="p" style="padding-left:25px;">
                4.4 Виробництво розташоване за адресою: <span class="fill">${physicalAddr}</span>.
            </div>
            <div class="p" style="padding-left:25px;">
                4.5 Філії знаходяться за адресою: <strong>не має.</strong>
            </div>
            <div class="p" style="padding-left:25px;">
                4.6 Банківські реквізити підприємства: <span class="fill">${bankDetails}</span>.
            </div>
            <div class="p" style="padding-left:25px;">
                4.7 Особа для зв'язку: <strong>посада</strong> <span class="fill">${contactPosition}</span>, <strong>ПІБ</strong> <span class="fill">${contactName}</span>, <strong>тел.</strong> <span class="fill">${phone}</span>, <strong>e-mail</strong> <span class="fill">${emailContact}</span>
            </div>

            <!-- Підписи -->
            <div class="signature">
                <div class="left">
                    <strong>Керівник організації</strong>
                </div>
                <div class="right">
                    <span class="line"></span>
                    <span class="name">Ольга СЕНДЕЦЬКА</span>
                </div>
            </div>
            <div class="m-p">М.П.</div>
        `;

        // Вставляємо в контейнер
        document.getElementById('documentContainer').innerHTML = docHtml;
    }

    // ===================================================
    //  ФУНКЦІЯ ЗАВАНТАЖЕННЯ .DOC (для Microsoft Word)
    // ===================================================
    function downloadDoc() {
        const content = document.getElementById('documentContainer').innerHTML;

        const fullHtml = `
            <html xmlns:o='urn:schemas-microsoft-com:office:office'
                  xmlns:w='urn:schemas-microsoft-com:office:word'
                  xmlns='http://www.w3.org/TR/REC-html40'>
            <head>
                <meta charset="utf-8">
                <title>Заявка ТФ-1-СУЯ</title>
                <style>
                    body { font-family: 'Times New Roman', serif; padding: 40px; max-width: 800px; margin: 0 auto; line-height:1.5; }
                    .header-right { text-align: right; margin-bottom: 20px; }
                    .doc-title { text-align: center; font-weight: 700; font-size: 18px; margin: 20px 0 10px; }
                    .p { margin-bottom: 6px; text-align: justify; }
                    .list { margin-left: 25px; margin-bottom: 8px; }
                    .list li { margin-bottom: 4px; }
                    .fill { text-decoration: underline; text-underline-offset: 2px; }
                    .signature { margin-top: 30px; display: flex; justify-content: space-between; align-items: center; }
                    .signature .right .line { display: inline-block; width: 150px; border-bottom: 1px solid #000; margin-right: 10px; }
                    .signature .right .name { font-weight: 700; letter-spacing: 1px; }
                    .m-p { text-align: right; margin-top: 5px; }
                    .label { font-weight: 700; }
                </style>
            </head>
            <body>
                ${content}
            </body>
            </html>
        `;

        const blob = new Blob([fullHtml], { type: 'application/msword;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        const companyName = document.getElementById('orgName').value || 'компанія';
        link.download = `Заявка_ТФ-1-СУЯ_${companyName}.doc`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(url);
    }

    // ===================================================
    //  АВТОМАТИЧНЕ ЗАПОВНЕННЯ НОМЕРА ЗАЯВКИ
    // ===================================================
    function generateAppNumber() {
        const year = new Date().getFullYear();
        const random = String(Math.floor(Math.random() * 10000)).padStart(4, '0');
        return `ТФ-1-СУЯ-${year}-${random}`;
    }

    // При завантаженні сторінки заповнюємо номер і оновлюємо прев'ю
    window.onload = function() {
        const numField = document.getElementById('appNumber');
        if (!numField.value) {
            numField.value = generateAppNumber();
        }
        updatePreview();
    };
</script>

</body>
</html>
